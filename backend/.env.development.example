# Puerto en el que corre la API
PORT=3000

# URL de la base de datos de PostgreSQL (ej. Neon o Postgres local)
# Reemplaza con tu cadena de conexión real
DATABASE_URL=postgres://usuario:contraseña@host:puerto/nombre_bd

# URL del Frontend para permitir CORS (opcional en desarrollo, por defecto permite localhost)
FRONTEND_URL=http://localhost:5173

# Secreto para firmar tokens JWT (puedes dejar el predeterminado para desarrollo)
JWT_SECRET=gosu-dev-secret-change-in-prod
